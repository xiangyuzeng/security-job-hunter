# Turso cloud database (required for Vercel deployment)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=eyJ...

# Email notifications (optional)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
NOTIFY_EMAIL=

# Dashboard URL for email links (optional, defaults to localhost)
DASHBOARD_URL=https://your-app.vercel.app
